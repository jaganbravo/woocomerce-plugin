# Local Docker only — copy to `.env` in this directory and fill in.
# Compose loads `.env` automatically for ${VAR} substitution. Do not commit `.env`.
#
# Dataviz AI for WooCommerce reads these from PHP getenv() — see:
# dataviz-ai-woocommerce-plugin/includes/class-dataviz-ai-api-client.php
#
# Use either OPENAI_API_KEY (common) or DATAVIZ_AI_API_KEY (plugin-specific).

OPENAI_API_KEY=
# DATAVIZ_AI_API_KEY=
# Optional: non-default API base (OpenAI-compatible)
# DATAVIZ_AI_API_BASE_URL=
